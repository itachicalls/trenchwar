; Engine configuration file.
; THE TRENCHES - a toy soldier open-world action adventure.

config_version=5

[application]

config/name="The Trenches"
config/description="Cinematic toy-soldier warfare across a giant suburban house."
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.3")
config/icon="res://icon.svg"

[autoload]

Events="*res://autoload/Events.gd"
Game="*res://autoload/Game.gd"
Missions="*res://autoload/Missions.gd"
Sfx="*res://autoload/Sfx.gd"

[display]

window/size/viewport_width=1600
window/size/viewport_height=900
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[physics]

3d/default_gravity=24.0

[rendering]

anti_aliasing/quality/msaa_3d=2
environment/defaults/default_clear_color=Color(0.05, 0.06, 0.11, 1)

